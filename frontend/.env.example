# Backend API URL
VITE_API_URL=http://localhost:8000/api/v1

# ApiMedic Credentials (Symptom Checker)
# Sign up at https://apimedic.com/ to get your credentials
# Free trial: 300 requests, Basic: $9.99/month
VITE_APIMEDIC_USERNAME=your-username-here
VITE_APIMEDIC_PASSWORD=your-password-here

# Google Maps API Key (For finding nearby doctors)
# Get at https://console.cloud.google.com/
# Enable: Places API, Maps JavaScript API
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
